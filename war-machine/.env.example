# ─── War Machine — Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your real values.
# NEVER commit .env to git.

# Supabase (use Service Role key — NOT anon key)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenRouter — get key at openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default free model
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Resend — get key at resend.com/api-keys
RESEND_API_KEY=re_...

# Email sender (must be a verified domain in Resend)
FROM_EMAIL=recon@forgeguard.ai
FROM_NAME=ForgeGuard AI — Recon Division

# Your live app URL (for CTA links + click tracking)
APP_BASE_URL=https://forgeguard.ai
TRACK_BASE_URL=https://forgeguard.ai/api/track

# Scraper tuning
MAX_LEADS_PER_RUN=50
HEADLESS=true
EMAIL_DELAY_SECONDS=2.5
SCRAPE_DELAY_SECONDS=1.5
